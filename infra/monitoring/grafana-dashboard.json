        {
          "expr": "sum(rate(http_requests_total{namespace=\"prism-era\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{namespace=\"prism-era\"}[5m]))",
          "refId": "A"
        }
      ]
    },
